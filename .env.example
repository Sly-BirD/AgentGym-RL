# ==============================================================================
# RL-WebNav Agent — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values.
# This file documents every configurable parameter.
# ==============================================================================

# --- Model Configuration ---
# Path to the base LLM model (downloaded from HuggingFace)
# On cloud: relative to the repo root
MODEL_PATH=models/Qwen2.5-7B-Instruct

# --- Environment Server ---
# URL where the WebArena environment server is running
# The environment server wraps web apps in Docker and provides
# an HTTP API (reset, step, observe) for the agent to interact with.
ENV_SERVER_URL=http://127.0.0.1:36005

# --- Training Hyperparameters ---
# See implementation_plan.md for detailed explanations of each parameter.
#
# ALGORITHM: Which RL algorithm to use for advantage computation
#   - grpo: Group Relative Policy Optimization (simpler, no critic needed)
#   - gae: Generalized Advantage Estimation (requires critic network)
ALGORITHM=grpo

# ROLLOUT_N: How many trajectories to generate per task prompt during training
#   Higher = better GRPO comparison but more compute
#   GRPO needs N≥2 to compare (typically N=4)
ROLLOUT_N=4

# LEARNING_RATE: How fast the policy updates
#   Too high = unstable training, policy collapses
#   Too low = very slow learning
LEARNING_RATE=1e-6

# KL_COEF: Strength of the KL divergence penalty
#   Prevents the trained model from diverging too far from the base model
#   Higher = more conservative (stays closer to base model)
#   Lower = more aggressive (allows bigger changes)
KL_COEF=0.001

# HORIZON: Maximum number of interaction turns per episode
#   For fixed horizon: single number (e.g., 15)
#   For ScalingInter-RL: comma-separated list (e.g., 5,10,15)
HORIZON=15

# TOTAL_EPOCHS: Number of complete passes through the training data
TOTAL_EPOCHS=25

# TRAIN_BATCH_SIZE: Number of tasks per training batch
TRAIN_BATCH_SIZE=32

# --- Weights & Biases (Experiment Tracking) ---
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=rl-webnav-agent
WANDB_ENTITY=your_username

# --- Dashboard ---
DASHBOARD_PORT=7860

# --- Cloud Specific ---
# For Lightning.ai, set the studio URL
LIGHTNING_STUDIO_URL=
